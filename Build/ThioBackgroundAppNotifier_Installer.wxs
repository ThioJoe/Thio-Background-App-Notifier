<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

    <!-- GUIDs -->
    <?define UpgradeCodeGuid = "c0de4349-0f65-45b6-a53d-ee0c1b1c8de0" ?>
    <?define ComponentGuidX64 = "4b47810d-b002-4ffa-bf28-01c24d70ba8f" ?>

    <!-- Set variables depending on specific 64 bit architecture -->
    <?if $(sys.BUILDARCH) = x64 ?>
        <?define ComponentGuid64BitToUse = "$(var.ComponentGuidX64)" ?>
	<!--  There's currently no arm64 version but will keep this just because. -->
    <?elseif $(sys.BUILDARCH) = arm64 ?>
        <?define ComponentGuid64BitToUse = "$(var.ComponentGuidArm64)" ?>
    <?endif ?>

    <!-- Scope="perUserOrMachine" makes this a dual-purpose package: the user can install it
         "for all users" (per-machine, into Program Files, requires elevation) OR "just for me"
         (per-user, into %APPDATA%, no admin rights needed). It defaults to per-user and sets
         ALLUSERS=2 + MSIINSTALLPERUSER=1 automatically; the InstallScopeDlg (added below) lets an
         elevated user pick, and the folder is retargeted at runtime by the custom actions further down. -->
    <Package Name="Thio's Background App Notifier" Language="1033" Version="$(var.ProductVersion)" Manufacturer="ThioJoe" UpgradeCode="$(var.UpgradeCodeGuid)" Scope="perUserOrMachine">
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <Media Id="1" Cabinet="cab1.cab" EmbedCab="yes" />

			<!-- Define custom banner and dialog bitmaps for the installer -->
		<WixVariable Id="WixUIDialogBmp" Overridable="yes" Value="Resources\Dialog.png" />
		<WixVariable Id="WixUIBannerBmp" Overridable="yes" Value="Resources\Banner.png" />
			<!-- Define the main icon for the installer UI and Add/Remove Programs -->
			<!-- Apparently you have to first define the <Icon> then use that ID for the property. Can't just directly use the icon path in the APPPRODUCTION value -->
		<Icon Id="MyAppIcon" SourceFile="Resources\Thio-Background-App-Notifier-Icon.ico"/>
		<Property Id="ARPPRODUCTICON" Value="MyAppIcon" />

        <!-- If the installer were to ask for the installation directory, this would show. But currently it doesn't. -->
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />

        <!-- ============================ Per-user / per-machine scope setup ============================ -->
        <!-- Sub-folder appended under the chosen root. Per-machine => [ProgramFiles64Folder]\ThioJoe\...
             Per-user => [AppDataFolder]\ThioJoe\... (AppDataFolder is Roaming %APPDATA%). -->
        <Property Id="ApplicationFolderName" Value="ThioJoe\Thio's Background App Notifier" />
        <!-- Default radio selection on the scope dialog. Defaults to per-user ("just for you") to
             match the package's per-user default scope; an elevated user can still pick all-users.
             A non-elevated user is forced to per-user by the InstallScopeDlg publish events below. -->
        <Property Id="WixAppFolder" Value="WixPerUserFolder" />
        <!-- These enable both options on the shared InstallScopeDlg. They are WiX (build-time) variables,
             not MSI properties, and are required because that dialog references them in its conditions. -->
        <WixVariable Id="WixUISupportPerUser" Value="1" />
        <WixVariable Id="WixUISupportPerMachine" Value="1" />

        <UI>
            <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
            <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
            <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
            <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

            <DialogRef Id="ErrorDlg" />
            <DialogRef Id="FatalError" />
            <DialogRef Id="FilesInUse" />
            <DialogRef Id="MsiRMFilesInUse" />
            <DialogRef Id="PrepareDlg" />
            <DialogRef Id="ProgressDlg" />
            <DialogRef Id="ResumeDlg" />
            <DialogRef Id="UserExit" />
            <DialogRef Id="WelcomeDlg" />
            <DialogRef Id="InstallScopeDlg" />

            <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
            <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" />

            <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />

            <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
            <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />

            <!-- Fresh install flow: Welcome -> InstallScope (choose all-users / just-me) -> VerifyReady -->
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallScopeDlg" Condition="NOT Installed" />

            <Publish Dialog="InstallScopeDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />
            <!-- A standard (non-elevated) user can't install per-machine, so force the per-user choice for them. -->
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="WixAppFolder" Value="WixPerUserFolder" Order="1" Condition="!(wix.WixUISupportPerUser) AND NOT Privileged" />
            <!-- Set ALLUSERS and the install folder to match the selected scope. -->
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="ALLUSERS" Value="{}" Order="2" Condition="WixAppFolder = &quot;WixPerUserFolder&quot;" />
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="ALLUSERS" Value="1" Order="3" Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;" />
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="APPLICATIONFOLDER" Value="[WixPerUserFolder]" Order="4" Condition="WixAppFolder = &quot;WixPerUserFolder&quot;" />
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="APPLICATIONFOLDER" Value="[WixPerMachineFolder]" Order="5" Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;" />
            <!-- Set the "launch after install" target from the plain WixPer*Folder properties (computed
                 client-side by the folder custom actions), NOT [#File_64bit]. On a per-machine install the
                 retargeted APPLICATIONFOLDER directory is resolved server-side, so [#File_64bit] comes back
                 empty at the ExitDialog and the launch does nothing (or explorer opens Documents). These
                 properties are always available in the UI process, so the ExitDialog gets a real path. -->
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="WixShellExecTarget" Value="[WixPerUserFolder]\Thio-Background-App-Notifier.exe" Order="6" Condition="WixAppFolder = &quot;WixPerUserFolder&quot;" />
            <Publish Dialog="InstallScopeDlg" Control="Next" Property="WixShellExecTarget" Value="[WixPerMachineFolder]\Thio-Background-App-Notifier.exe" Order="7" Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;" />
            <Publish Dialog="InstallScopeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="8" />

            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="InstallScopeDlg" Order="2" Condition="NOT Installed" />

            <Property Id="ARPNOMODIFY" Value="1" />
       
        </UI>
        <UIRef Id="WixUI_Common" />

        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Thio's Background App Notifier" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" Value="Open the app to select the option to run a check at each startup." />

        <Feature Id="ProductFeature" Title="Thio's Background App Notifier">
            
            <!-- ========================= 64-bit Exe (x64 and ARM64) ========================= -->
            <Component Id="Component_64bit" Guid="$(var.ComponentGuid64BitToUse)" Bitness="always64" Directory="APPLICATIONFOLDER" >

                <?if $(sys.BUILDARCH) = x64 ?>
                    <File Id="File_64bit"
                            Name="Thio-Background-App-Notifier.exe"
                            Source="Thio-Background-App-Notifier.exe"
                            KeyPath="yes" 
                            Vital="yes"
                            PatchWholeFile="yes"
                            />
                <?endif?>
				
                <!--  There's currently no arm64 version but will keep this just because. -->
                <?if $(sys.BUILDARCH) = arm64 ?>
                    <File Id="File_64bit"
                            Name="Thio-Background-App-Notifier.exe"
                            Source="Thio-Background-App-Notifier.exe"
                            KeyPath="yes" 
                            Vital="yes"
                            PatchWholeFile="yes"
                            />
                <?endif?>
				
                <!-- This must match the app's own StartupShortcut (StartupShortcut.cs / MyStrings) so the
                     installer and the in-app "run at startup" toggle manage the same .lnk:
                       - Name  = MyStrings.StartupShortcutName  ("... (Quiet Mode)"); the suffix signals the
                                 silent logon launch so users don't think the startup entry is broken.
                       - Arguments = StartupShortcut.QuietArgument ("-quiet") so the launch is silent. -->
                <Shortcut Id="StartupShortcut"
                        Name="Thio's Background App Notifier (Quiet Mode)"
                        Description="Quietly checks for new startup services and scheduled tasks at logon."
                        Directory="StartupFolder"
                        Target="[#File_64bit]"
                        Arguments="-quiet"
                        WorkingDirectory="APPLICATIONFOLDER" />

                <!-- Start Menu launcher so the app shows up when searched. Normal launch (no -quiet),
                     no pinning, no desktop shortcut. ProgramMenuFolder is the All-Users Start Menu for an
                     all-users install and the current user's Start Menu for a per-user install. -->
                <Shortcut Id="StartMenuShortcut"
                        Name="Thio's Background App Notifier"
                        Description="Check for newly added startup services and scheduled tasks."
                        Directory="ProgramMenuFolder"
                        Target="[#File_64bit]"
                        WorkingDirectory="APPLICATIONFOLDER" />

            </Component>
			
        </Feature>
		
    </Package>

    <Fragment>
		<StandardDirectory Id="StartupFolder" />
		<!-- Start Menu \ Programs (per-user or All-Users, matching the install scope). -->
		<StandardDirectory Id="ProgramMenuFolder" />
		<!-- Roaming %APPDATA% root, used for the per-user install location. -->
		<StandardDirectory Id="AppDataFolder" />
        <!-- APPLICATIONFOLDER is retargeted at runtime by the custom actions below (Program Files for
             all-users, %APPDATA% for just-me). The authored location under Program Files is only a
             fallback; the actual path is always set via the APPLICATIONFOLDER property. -->
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="APPLICATIONFOLDER" Name="Thio's Background App Notifier" />
        </StandardDirectory>

        <!-- ================= Choose the install folder based on per-user vs per-machine =================
             This mirrors the logic WixUI_Advanced uses internally, but points the per-user folder at
             Roaming %APPDATA%\ThioJoe\... (instead of the WiX default LocalAppData\Apps\...) and the
             per-machine folder at 64-bit Program Files. Both defaults are computed early; the
             SetAppFolder* actions only apply them for silent/default installs where the UI hasn't
             already set APPLICATIONFOLDER (the InstallScopeDlg sets it directly when the UI runs). -->
        <CustomAction Id="SetDefaultPerUserFolder" Property="WixPerUserFolder" Value="[AppDataFolder][ApplicationFolderName]" Execute="immediate" />
        <CustomAction Id="SetDefaultPerMachineFolder" Property="WixPerMachineFolder" Value="[ProgramFiles64Folder][ApplicationFolderName]" Execute="immediate" />
        <CustomAction Id="SetAppFolderPerUser" Property="APPLICATIONFOLDER" Value="[WixPerUserFolder]" Execute="immediate" />
        <CustomAction Id="SetAppFolderPerMachine" Property="APPLICATIONFOLDER" Value="[WixPerMachineFolder]" Execute="immediate" />

        <InstallExecuteSequence>
            <Custom Action="SetDefaultPerUserFolder" Before="CostFinalize" />
            <Custom Action="SetDefaultPerMachineFolder" After="SetDefaultPerUserFolder" />
            <Custom Action="SetAppFolderPerUser" After="SetDefaultPerMachineFolder" Condition="ACTION=&quot;INSTALL&quot; AND APPLICATIONFOLDER=&quot;&quot; AND (ALLUSERS=&quot;&quot; OR (ALLUSERS=2 AND (NOT Privileged)))" />
            <Custom Action="SetAppFolderPerMachine" After="SetAppFolderPerUser" Condition="ACTION=&quot;INSTALL&quot; AND APPLICATIONFOLDER=&quot;&quot; AND (ALLUSERS=1 OR (ALLUSERS=2 AND Privileged))" />
        </InstallExecuteSequence>
        <InstallUISequence>
            <Custom Action="SetDefaultPerUserFolder" Before="CostFinalize" />
            <Custom Action="SetDefaultPerMachineFolder" After="SetDefaultPerUserFolder" />
            <Custom Action="SetAppFolderPerUser" After="SetDefaultPerMachineFolder" Condition="ACTION=&quot;INSTALL&quot; AND APPLICATIONFOLDER=&quot;&quot; AND (ALLUSERS=&quot;&quot; OR (ALLUSERS=2 AND (NOT Privileged)))" />
            <Custom Action="SetAppFolderPerMachine" After="SetAppFolderPerUser" Condition="ACTION=&quot;INSTALL&quot; AND APPLICATIONFOLDER=&quot;&quot; AND (ALLUSERS=1 OR (ALLUSERS=2 AND Privileged))" />
        </InstallUISequence>

        <!-- Launch the app after install. WixShellExec does a ShellExecute on [WixShellExecTarget]
             (set by the InstallScopeDlg above to the full exe path), so it handles the spaces/apostrophe
             in the path correctly. Impersonate="yes" runs it as the installing user. -->
        <CustomAction Id="LaunchApplication" BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)" DllEntry="WixShellExec" Impersonate="yes" />

        <util:CloseApplication Id="CloseMyApp" Target="Thio-Background-App-Notifier.exe" CloseMessage="no" RebootPrompt="no" TerminateProcess="1" />

    </Fragment>

</Wix>